# Vibo (vibodj.com) credentials — choose ONE of the two auth methods.

# Method 1 (recommended): email + password sign-in.
VIBO_EMAIL=you@example.com
VIBO_PASSWORD=your_password

# Method 2: paste a captured access token (use this if your account only signs
# in via Apple / Google / Facebook, so there is no password). Capture x-token /
# x-refresh-token from a signed-in web.vibodj.com session.
# VIBO_ACCESS_TOKEN=
# VIBO_REFRESH_TOKEN=

# Optional: override the API endpoint (defaults to https://api.vibodj.com/v2/graphql).
# VIBO_API_URL=
